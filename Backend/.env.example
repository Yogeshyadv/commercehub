# Environment Variables Configuration

# Server Configuration
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
# --- Development (local MongoDB) ---
# Set NODE_ENV=development and MONGO_URI_LOCAL to use your local MongoDB instance.
# Install MongoDB locally: https://www.mongodb.com/try/download/community
MONGO_URI_LOCAL=mongodb://localhost:27017/commercehub

# --- Production (MongoDB Atlas / cloud) ---
# This is the only var read in production (NODE_ENV=production).
# Set this in your hosting provider (Render, Railway, etc.) environment variables.
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/commercehub?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OpenAI (AI Features)
OPENAI_API_KEY=sk-xxx

# Razorpay (Payment Gateway)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-secret

# Twilio (WhatsApp & SMS)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp AI Agent
# In dev: use ngrok to expose localhost → https://xxxxx.ngrok.io
API_URL=http://localhost:5000
# Razorpay webhook secret (from Razorpay dashboard → Webhooks)
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
# Meta webhook verify token (only needed if using Meta Business API instead of Twilio)
WEBHOOK_VERIFY_TOKEN=your-random-secret-token

# Redis (Caching) - Add when implementing
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Email (SMTP) - Required for email verification
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=NextGen B2B <noreply@nextgen.com>

# Stripe (Payment Gateway) - Add when implementing
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# Elasticsearch - Add when implementing
# ELASTICSEARCH_NODE=http://localhost:9200

# Sentry (Error Tracking) - Add when implementing
# SENTRY_DSN=your-sentry-dsn

# AWS S3 (Alternative to Cloudinary) - Optional
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Custom Domain Settings
# SSL_CERT_PATH=/path/to/cert
# SSL_KEY_PATH=/path/to/key
